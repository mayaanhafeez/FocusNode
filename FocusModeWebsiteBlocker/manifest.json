{
  "manifest_version": 3,
  "name": "Focus Mode Blocker",
  "version": "1.1.0",
  "description": "Blocks selected sites when Focus Mode is enabled.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "sw.js",
    "scripts": ["sw.js"]
  },
  "options_ui": {
    "page": "dist/options.html",
    "open_in_tab": true
  },
  "action": { "default_title": "Focus Mode", "default_popup": "dist/popup.html" },
  "browser_specific_settings": {
    "gecko": {
      "id": "focusnode@ayaanhafeez.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
